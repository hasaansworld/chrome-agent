{
  "manifest_version": 3,
  "name": "LangChain Web Agent",
  "version": "2.0",
  "description": "Advanced web automation assistant powered by LangChain",
  "permissions": [
    "activeTab",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://api.groq.com/*",
    "http://localhost:3001/*",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["langchain-client.js", "content.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open LangChain Web Agent"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  }
}