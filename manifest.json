{
  "manifest_version": 3,
  "name": "Chrome Agent",
  "version": "1.0",
  "description": "An AI agent that can operate your browser, in a side panel.",
  "permissions": [
    "activeTab",
    "sidePanel",
    "tabs",
    "scripting",
    "storage",
    "debugger"
  ],
  "host_permissions": [
    "https://api.anthropic.com/*",
    "https://api.openai.com/*",
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "action": {
    "default_title": "Open Chrome Agent"
  },
  "side_panel": {
    "default_path": "src/sidebar/index.html"
  }
}
