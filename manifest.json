{
  "manifest_version": 3,
  "name": "Chat Assistant",
  "version": "1.0",
  "description": "AI Chat Assistant sidebar",
  "permissions": [
    "activeTab",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "https://api.openai.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Chat Assistant"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  }
}