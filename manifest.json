{
  "manifest_version": 3,
  "name": "Chat Assistant",
  "version": "1.0",
  "description": "AI Chat Assistant sidebar",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "https://api.groq.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["sidebar.js", "content.js"],
      "css": ["sidebar.css"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Chat Assistant"
  }
}